# Copy this file to .env and fill in what you have. Nothing here is required
# for the app to run — every platform falls back to mock data until its
# credentials are present. See SETUP.md for how to get each one.

PORT=8787
FRONTEND_URL=http://localhost:5173
SERVER_URL=http://localhost:8787

# --- Twitch (dev.twitch.tv/console/apps) ---
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- YouTube / Google Cloud (console.cloud.google.com) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- TikTok & Instagram via Apify (apify.com) ---
# No OAuth, no app review — just one Apify API token, shared by both
# platforms. Usernames are entered directly in Settings, not here.
# See SETUP.md.
APIFY_API_TOKEN=

# --- Persistent storage (optional) ---
# Leave both blank for local dev — falls back to tokens.json/app-data.json
# on disk. Set both when deploying somewhere with an ephemeral filesystem
# (e.g. Render's free tier) so real data survives redeploys/restarts. Get
# these from an Upstash Redis database's REST API tab (upstash.com, free).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
